{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/assets/(.*)", "dest": "/Figma/dist/assets/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/Figma/dist/index.html" }
  ]
}
